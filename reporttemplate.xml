<ReportList>
  <Report>
    <!-- Apply to all folder types and processes -->
    <foldertype>ACT</foldertype>
    <processcode>473210</processcode>
    <reportname>Inspection Report</reportname>
    <reportdescription>Inspection Report</reportdescription>
    <displayflag>Y</displayflag>

    <reporttemplate>
      <![CDATA[

 <!-- HEADER -->
 <div class="report_row align_space-between">
    <div>
       <img src="data:image/png;base64," style="height:120px;" />
        </div>
        <div class="align_center font_s">
          <div>1595 Bedford Highway, Suite 224</div>
          <div>Bedford, N.S. B4A 3Y4</div>
        </div>
        <div>
            <div>Phone:(902) 424-7773</div>
        </div>
      </div>

      <div class="report_row top_indent_m font_s align_right">
        <span class="make_bold">Process RSN Number:</span>
        {{InspectionProcessMetricsDetails.ProcessRSN}}
      </div>

      <!-- TITLE -->
      <div class="report_row align_center top_indent_l">
        <div class="make_bold make_underline make_underlinefont_xl">INSPECTION REPORT</div>
      </div>
	  
	  <!-- SUB TITLE -->
      <div class="report_row align_center top_indent_l">
        <div class="make_bold make_underline font_xl">{{folderProcess}}</div>
      </div>

      <!-- INSPECTION DETAILS -->
      <div class="report_row top_indent_l">
        <span class="make_bold">APPLICATION / PERMIT NUMBER:</span>
        {{FolderDetails[0].FolderNumber.substring(0, 15)}}
      </div>
    	<!--LINE BREAK-->
    	<div id="printContent" style="white-space: pre-wrap; visibility:hidden;"> </div>
     
	     <!--PEOPLE ROLE-->
      <div class="report_row">
        <span class="make_bold">INSPECTEE: </span>
		    {{PeopleDetails[0].Organization}}
      </div>
    	<!--LINE BREAK-->
     <div id="printContent" style="white-space: pre-wrap; visibility:hidden;"> </div>
      <div class="report_row">
        <span class="make_bold">INSPECTION DATE:</span>
        {{InspectionProcessMetricsDetails.AttemptSignDate}}
      </div>
      <!--LINE BREAK-->
     <div id="printContent" style="white-space: pre-wrap; visibility:hidden;"> </div>
      <div class="report_row">
        <span class="make_bold">FACILITY / SITE NAME: </span>
        {{FolderDetails[0].FolderName}}
      </div>
       <!--LINE BREAK-->
      <div id="printContent" style="white-space: pre-wrap; visibility:hidden;"> </div>
      <div class="report_row">
        <span class="make_bold">SITE ADDRESS: </span>
        {{PropertyDetails[0].Address}}
      </div>

      <div class="report_row make_border top_indent_m"></div>

      <!-- OVERVIEW -->
      <div class="report_row make_underline top_indent_m make_bold">
        OVERVIEW OF INSPECTION
      </div>

      <div class="report_row">
        <div style="white-space: pre-wrap;">
          {{InspectionProcessMetricsDetails.AttemptComment}}
        </div>
      </div>

      <!-- FOOTER -->
      <div class="report_row top_indent_l font_xs">
        This inspection report was prepared on
        {{InspectionProcessMetricsDetails.AttemptSignDate}}
        by {{ValidUser.UserName}} with Nova Scotia Department of Environment
        and Climate Change.
      </div>

      <div class="report_row font_xs top_indent_s">
        Nova Scotia Department of Environment and Climate Change<br/>
        1595 Bedford Highway, Suite 224<br/>
        Bedford, N.S. B4A 3Y4<br/>
        Phone: (902) 424-7773<br/>
      </div>
    
    <div class="report_row font_xs top_indent_s">
      <span> https://novascotia.ca/nse</span>
    </div>

      ]]>
    </reporttemplate>

    <reportType>CUSTOM</reportType>
  </Report>
</ReportList>
