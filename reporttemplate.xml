<?xml version="1.0" encoding="UTF-8"?>
<ReportList>
<Report>
<foldertype></foldertype>
<processcode></processcode>
<reportname>Custom</reportname>
<reportdescription>This is Custom Report</reportdescription>
<displayflag>Y</displayflag>
<reporttemplate>
<![CDATA[
<div>
<br />
 <div class="report_row align_right make_bold">Sample Report</div>
 <br /> 
 <div class="report_row ">
 <div class="field_name ">Folder RSN</div>
 <div class="field_value ">{{FolderDetails[0].FolderNumber}}
 </div>
 </div>
<br />
<div class="report_row align_space-between">
<div class="report_field two_column_feild align_space-between">
<div class="field_name">StartDate</div>
<div class="field_value">{{InspectionProcessMetricsDetails.StartDate}}</div>
</div>
<div class="report_field two_column_feild align_space-between">
<div class="field_name">AttemptUnit</div>
<div class="field_value">{{InspectionProcessMetricsDetails.AttemptUnit}}</div>
</div>
</div>
<br />


</div>
<br />
<div class="report_row align_center make_bold make_italic">Deficiency 
List</div>
<div class="report_row align_space-between" ng-repeat="item in reportVar.deficiencyList">
<div class="field_name make_bold">{{item.deficiencytext}}</div>
<div class="field_value make_italic">{{item.deficiencydesc}} </div>
<div class="report_row" ng-if="!reportVar.deficiencyList.length">There is no deficiency</div>
<br />
<div class="report_row align_center">Inspection Checklist</div>
<div class="report_row align_space-between" ng-repeat="item in reportVar.checkList">
<div class="field_name">{{item.checklistdesc}}</div>
<div class="field_value" ng-if="item.notapplicableflag 
==='Y'">NA</div>
<div class="field_value" ng-if="item.passed === 'Y' && item.notapplicableflag !== 'Y'">Passed</div>
<div class="field_value" ng-if="item.passed !=='Y' && item.notapplicableflag !== 'Y'">Fail</div>
</div>
<div class="report_row" ng-if="!reportVar.checkList.length">There is 
  no checklist</div>
]]>
</reporttemplate>
<reportType>custom</reportType>
</Report>
</ReportList>

